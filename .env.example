# Kiwoom Securities REST API credentials — copy to `.env` and fill in.
# NEVER commit the real `.env` (already listed in .gitignore).

# From Kiwoom developer center (openapi.kiwoom.com > 앱 등록).
# The account is bound to the app key — no separate account-number variable.
# NOTE: VIRTUAL and REAL use separately issued app keys.
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=

# VIRTUAL = 모의투자 (https://mockapi.kiwoom.com)
# REAL    = 실전투자 (https://api.kiwoom.com)
KIWOOM_MODE=VIRTUAL

# ─── ISA tax tool (OPTIONAL) ────────────────────────────────────────────────
# The server is general-account-first: by default only the generic market-data
# and account-inquiry tools are exposed. If you connect an ISA account and want
# the `calc_isa_tax_status` tool, set ISA_ENABLED=true and fill in the two ISA
# fields below. For a normal (non-ISA) account, leave this false — the ISA tool
# is not registered and the two fields below are ignored.
ISA_ENABLED=false

# ISA type for the tax-free limit: GENERAL (일반형, 2,000,000 KRW) or
# SEOMIN (서민형/농어민형, 4,000,000 KRW). Only used when ISA_ENABLED=true.
ISA_TYPE=GENERAL

# ISA account opening date (yyyy-MM-dd) — default aggregation start date for
# calc_isa_tax_status (realized P&L / dividends are summed from this date).
# Only used when ISA_ENABLED=true; can be overridden per call via the from_date
# tool argument.
ISA_OPENED_ON=

# ─── Remote access / HTTP mode (OPTIONAL) ───────────────────────────────────
# Default transport is stdio (Claude Desktop/Code). Set MCP_TRANSPORT=http (or
# run with --http) to serve Streamable HTTP for claude.ai custom connectors.
# HTTP mode refuses to start without MCP_AUTH_TOKEN (every /mcp request must
# send `Authorization: Bearer <token>`); opt out only with an explicit
# --no-auth / MCP_HTTP_NO_AUTH=true on a trusted network or VIRTUAL key.
#MCP_TRANSPORT=http
#MCP_AUTH_TOKEN=
#MCP_HTTP_PORT=8000
#MCP_HTTP_HOST=127.0.0.1
