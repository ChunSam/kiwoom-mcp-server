# Kiwoom Securities REST API credentials — copy to `.env` and fill in.
# NEVER commit the real `.env` (already listed in .gitignore).

# From Kiwoom developer center (openapi.kiwoom.com > 앱 등록).
# The account is bound to the app key — no separate account-number variable.
# NOTE: VIRTUAL and REAL use separately issued app keys.
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=

# VIRTUAL = 모의투자 (https://mockapi.kiwoom.com)
# REAL    = 실전투자 (https://api.kiwoom.com)
KIWOOM_MODE=VIRTUAL

# ISA type for tax-limit calculation: GENERAL (일반형, 2,000,000 KRW)
# or SEOMIN (서민형/농어민형, 4,000,000 KRW)
ISA_TYPE=GENERAL

# ISA account opening date (yyyy-MM-dd) — default aggregation start date for
# calc_isa_tax_status (realized P&L / dividends are summed from this date).
# Can be overridden per call via the from_date tool argument.
# Leave blank if this is NOT an ISA account (e.g. a mock/general account):
# calc_isa_tax_status simply has no default start date; all other tools are
# unaffected.
ISA_OPENED_ON=
